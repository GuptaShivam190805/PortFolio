---
import LikeButton from "../React/LikeButton.tsx";

const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-10">

      <!-- Social Links -->
      <div class="flex flex-col lg:items-start items-center space-y-6 gap-9">

        <div class="flex space-x-6 sm:space-x-8">

          {
            [
              {
                href: "https://github.com/GuptaShivam190805",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8"><path d="M12.001 2C6.476 2 2 6.476 2 12c0 4.425 2.863 8.163 6.838 9.488.5.087.688-.213.688-.475 0-.238-.013-1.025-.013-1.862-2.512.463-3.162-.613-3.362-1.175-.112-.288-.6-1.175-1.025-1.413-.35-.187-.85-.65-.013-.662.788-.013 1.35.725 1.538 1.025.9 1.513 2.338 1.088 2.913.825.087-.65.35-1.088.638-1.338-2.225-.25-4.55-1.112-4.55-4.937 0-1.088.388-1.988 1.025-2.688-.1-.25-.45-1.275.1-2.65 0 0 .838-.262 2.75 1.025a9.6 9.6 0 0 1 2.5-.338c.85 0 1.7.113 2.5.338 1.912-1.3 2.75-1.025 2.75-1.025.55 1.375.2 2.4.1 2.65.637.7 1.025 1.6 1.025 2.688 0 3.825-2.338 4.675-4.563 4.925.363.312.675.912.675 1.85 0 1.338-.012 2.413-.012 2.75 0 .262.187.575.687.475A10.02 10.02 0 0 0 22 12c0-5.524-4.476-10-9.999-10Z"/></svg>`,
                label: "GitHub",
              },
              {
                href: "https://www.linkedin.com/in/shivam-gupta-86b5b32a7/",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8"><path d="M18.336 18.339h-2.665v-4.177c0-.996-.02-2.278-1.389-2.278-1.39 0-1.602 1.084-1.602 2.204v4.251h-2.665V9.75h2.561v1.171h.034c.358-.675 1.228-1.388 2.528-1.388 2.701 0 3.201 1.778 3.201 4.092v4.714zM7.004 8.575a1.548 1.548 0 1 1 0-3.096 1.548 1.548 0 0 1 0 3.096zM8.34 18.339H5.667V9.75H8.34v8.589zM19.669 3H4.329A1.33 1.33 0 0 0 3 4.297v15.406C3 20.42 3.595 21 4.329 21h15.338c.734 0 1.334-.58 1.334-1.297V4.297C21 3.58 20.401 3 19.669 3z"/></svg>`,
                label: "LinkedIn",
              },
              {
                href: "mailto:sg5743006@gmail.com",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.1em" height="2.1em" viewBox="0 0 24 24"><path fill="currentColor" d="M18.73 5.41 12 10.46 5.27 5.41A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64Z"/></svg>`,
                label: "Email",
              },
            ].map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col items-center group"
                aria-label={link.label}
              >
                <div class="text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300">
                  <div set:html={link.icon} />
                </div>
              </a>
            ))
          }

        </div>

        <LikeButton client:load />

      </div>

      <!-- Tech Stack -->
      <div class="flex flex-col items-center space-y-6">

        <div class="grid grid-cols-1 gap-3 w-full max-w-xs py-6">

          <div class="flex items-center justify-center lg:justify-normal space-x-3">
            <span class="text-[var(--white-icon)] text-sm">Styled with</span>
            <img src="/svg/tailwindcss.svg" class="h-5 w-5 invert opacity-50" />
            <span class="text-[var(--white-icon)] text-sm">TailwindCSS</span>
          </div>

          <div class="flex items-center justify-center lg:justify-normal space-x-3">
            <span class="text-[var(--white-icon)] text-sm">Deployed on</span>
            <img src="/svg/vercel.svg" class="h-5 w-5 invert opacity-50" />
            <span class="text-[var(--white-icon)] text-sm">Vercel</span>
          </div>

        </div>

      </div>

      <!-- Spotify -->
      <div class="flex flex-col items-center lg:items-start space-y-6">

        <div class="w-full max-w-xs">

          <iframe
            style="border-radius:12px;border:0;"
            src="https://open.spotify.com/embed/artist/6QoCrBHsojKnOrsGNfRcTN"
            class="w-full h-80"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy">
          </iframe>

        </div>

      </div>

    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-[#ffffff10]">

      <p class="text-center text-sm text-[var(--white-icon)]">

        Copyright © {currentYear}
        <a href="https://github.com/GuptaShivam190805">
          Shivam Gupta
        </a>
        . All rights reserved.

      </p>

    </div>

  </div>
</footer>